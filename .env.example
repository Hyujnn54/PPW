# ─────────────────────────────────────────────────────────────────
#  PPW - Personal Password Manager  |  Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────
# Get from: Atlas → Cluster → Connect → Drivers → copy the URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=PPW
DATABASE_NAME=password_manager

# ── Email / SMTP (disabled by default — uncomment when you want emails) ───────
# Sends welcome emails on registration and login alerts.
# Works with Gmail, Outlook, Zoho, or any SMTP provider.
#
# Gmail setup:
#   1. Enable 2FA → myaccount.google.com → Security → App Passwords → generate one
#   2. Paste the app password as SMTP_PASSWORD (NOT your real Gmail password)
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password-here
# FROM_NAME=PPW Password Manager
# FROM_EMAIL=your-email@gmail.com
