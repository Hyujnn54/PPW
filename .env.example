# ─────────────────────────────────────────────────────────────────
#  PPW - Personal Password Manager  |  Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────
# Get from: Atlas → Cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>
DATABASE_NAME=password_manager

# ── Security ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_string

# ── Email (transactional — welcome email, login alerts) ───────────
# Works with Gmail, Outlook, Zoho, or any SMTP provider.
#
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Create an app password and paste it as SMTP_PASSWORD below
#   (Never use your real Gmail password here)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
FROM_NAME=PPW Password Manager
FROM_EMAIL=your-email@gmail.com
